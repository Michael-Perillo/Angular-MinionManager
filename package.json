{
  "name": "angular-minion-manager",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadless --code-coverage",
    "test:models": "ng test --no-watch --browsers=ChromeHeadless --include=**/models/**/*.spec.ts",
    "test:services": "ng test --no-watch --browsers=ChromeHeadless --include=**/services/**/*.spec.ts",
    "test:components": "ng test --no-watch --browsers=ChromeHeadless --include=**/components/**/*.spec.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "storybook": "ng run Angular-MinionManager:storybook",
    "build-storybook": "ng run Angular-MinionManager:build-storybook",
    "test:storybook": "test-storybook --coverage",
    "coverage:merge": "mkdir -p coverage/.nyc_merge && cp coverage/angular-minionmanager/coverage-final.json coverage/.nyc_merge/karma.json && cp coverage/storybook/coverage-storybook.json coverage/.nyc_merge/storybook.json && nyc merge coverage/.nyc_merge coverage/merged/coverage-final.json",
    "coverage:check": "nyc check-coverage --temp-dir coverage/merged",
    "coverage:check:core": "nyc check-coverage --temp-dir coverage/angular-minionmanager --lines 60 --statements 60 --branches 45 --functions 50",
    "coverage:report": "nyc report --temp-dir coverage/merged --reporter=text --reporter=lcov --report-dir coverage/merged",
    "test:storybook:viewport": "playwright test --config playwright-storybook.config.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2000.0",
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular-devkit/core": "^20.0.0",
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@compodoc/compodoc": "^1.2.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-coverage": "^3.0.0",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/angular": "^10.2.8",
    "@storybook/test-runner": "^0.24.2",
    "@types/jasmine": "~5.1.0",
    "http-server": "^14.1.1",
    "jasmine-core": "~5.7.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nyc": "^18.0.0",
    "storybook": "^10.2.8",
    "typescript": "~5.8.2"
  }
}
